#include <stdio.h>

int main() {
    int arr[5];
    int *ptr;
    int i;

    // Read array elements
    printf("Enter 5 elements of the array: ");
    for(i = 0; i < 5; i++) {
        scanf("%d", &arr[i]);
    }

    // Pointer points to the first element of array
    ptr = arr;

    printf("Array elements accessed using pointer:\n");
    for(i = 0; i < 5; i++) {
        printf("%d ", *(ptr + i));
    }
    printf("\n");

    return 0;
}
